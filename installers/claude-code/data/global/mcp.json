{
    "mcpServers": {
        "Home Assistant": {
            "command": "uvx",
            "args": ["ha-mcp@latest"],
            "env": {
                "HOMEASSISTANT_URL": "${HOMEASSISTANT_URL}",
                "HOMEASSISTANT_TOKEN": "${HOMEASSISTANT_TOKEN}"
            }
        },
        "context7": {
            "type": "http",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
            }
        }
    }
}
